---
// Component Imports
import BackToTop from '../components/BackToTop.astro';
import MainHead from '../components/MainHead.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import ThemeWrapper from '../components/ThemeWrapper.tsx';
import PasswordGate from '../components/PasswordGate.astro';


interface Props {
  title?: string | undefined;
  description?: string | undefined;
  protected?: boolean | undefined;
}

const { title, description, protected: isProtected } = Astro.props;
---

<html lang="en" {...(isProtected ? { 'data-protected': '' } : {})}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />

    <title>{title ? `Summer Young: ${title}` : 'Summer Young'}</title>
    {isProtected && (
      <script is:inline>
        if (sessionStorage.getItem('portfolio-auth') === 'authenticated') {
          document.documentElement.removeAttribute('data-protected');
        }
      </script>
    )}
  </head>
  <body>
    {isProtected && <PasswordGate />}
    <header>
      <MainHead title={title} description={description} />

      <Nav />
    </header>
    <ThemeWrapper client:load>
      <slot />
      <BackToTop />
    </ThemeWrapper>
    <Footer />

    <script>
      // Add “loaded” class once the document has completely loaded.
      addEventListener('load', () =>
        document.documentElement.classList.add('loaded')
      );
    </script>
  </body>
</html>
