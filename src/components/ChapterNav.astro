---
export interface Chapter {
  id: string;
  text: string;
}

interface Props {
  chapters: Chapter[];
}

const { chapters } = Astro.props;
---

<nav class="chapter-nav" aria-labelledby="chapters-title">
  <h2 class="chapters-title" id="chapters-title">Chapters</h2>
  <ol class="chapter-list">
    {
      chapters.map((chapter) => (
        <li>
          <a
            href={`#${chapter.id}`}
            class="chapter-link"
            data-heading-id={chapter.id}
          >
            <span class="chapter-num" aria-hidden="true" />
            <span>{chapter.text}</span>
          </a>
        </li>
      ))
    }
  </ol>
</nav>

<style>
  .chapters-title {
    font-family: var(--font-brand);
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--gray-400);
    margin-bottom: 12px;
    padding-left: 2px;
  }

  .chapter-list {
    list-style: none;
    margin: 0;
    padding: 0;
    /* Numbering mirrors the chapter headings in the article body. */
    counter-reset: chapter;
  }

  .chapter-list li {
    counter-increment: chapter;
  }

  .chapter-link {
    display: flex;
    gap: 12px;
    padding: 9px 0;
    font-size: var(--text-sm);
    color: var(--gray-300);
    text-decoration: none;
    border-top: 1px solid var(--gray-800);
    transition: color var(--theme-transition);
  }

  .chapter-num::before {
    content: counter(chapter, decimal-leading-zero);
    font-family: var(--font-brand);
    font-size: 12px;
    font-weight: 600;
    color: var(--accent-dark);
  }

  .chapter-link:hover,
  .chapter-link:focus-visible {
    color: var(--accent-dark);
  }

  .chapter-link.active {
    color: var(--accent-dark);
    font-weight: 500;
  }
</style>

<script>
  function initChapterNav() {
    const links = document.querySelectorAll<HTMLAnchorElement>('.chapter-link');
    if (links.length === 0) return;

    const setActive = (id: string) => {
      links.forEach((link) =>
        link.classList.toggle('active', link.dataset.headingId === id)
      );
    };

    links.forEach((link) => {
      link.addEventListener('click', () => {
        const id = link.getAttribute('href')?.substring(1);
        if (id) setActive(id);
      });
    });

    const chapters = [...links]
      .map((link) => document.getElementById(link.dataset.headingId ?? ''))
      .filter((el): el is HTMLElement => el !== null);

    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) setActive(entry.target.id);
        });
      },
      { rootMargin: '-20% 0px -70% 0px' }
    );

    chapters.forEach((chapter) => observer.observe(chapter));
  }

  initChapterNav();
  document.addEventListener('astro:page-load', initChapterNav);
</script>
