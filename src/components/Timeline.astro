---
import { ArrowRightIcon } from '@radix-ui/react-icons';

import LogoBestBuy from './LogoBestBuy.astro';
import LogoVisa from './LogoVisa.astro';

/** Employer marks, keyed by the `logo` value an event opts into. */
const logos = {
  visa: LogoVisa,
  'best-buy': LogoBestBuy,
};

interface TimelineLink {
  href: string;
  label: string;
}

interface TimelineEvent {
  year: string;
  place: string;
  title: string;
  body: string;
  /** Second paragraph — the reflection, set a step back from the body. */
  more?: string;
  /** Aside below the card, in the alternating margin. */
  note?: string;
  /** Short badge summarizing the stop (tools, role, or credential). */
  stat?: string;
  /** Employer mark shown ahead of the year. Decorative — the place name
      beside it already carries the company. */
  logo?: keyof typeof logos;
  links?: TimelineLink[];
}

interface Props {
  events: TimelineEvent[];
}

const { events } = Astro.props;
---

<div class="timeline" data-timeline>
  <div class="spine" data-spine aria-hidden="true"></div>

  <ol class="events">
    {
      events.map((event) => {
        const Logo = event.logo ? logos[event.logo] : null;

        return (
          <li class="event reveal">
            <div class="node-col" aria-hidden="true">
              <span class="node" />
            </div>
            <div class="card-col">
              <article class="card">
                <div class="card-meta">
                  {Logo && (
                    <span class:list={['logo', `logo-${event.logo}`]}>
                      <Logo />
                    </span>
                  )}
                  <span class="year">{event.year}</span>
                  <span class="place">{event.place}</span>
                </div>
                <h3 class="card-title">{event.title}</h3>
                <p class="card-body">{event.body}</p>
                {event.more && <p class="card-more">{event.more}</p>}
                {event.stat && (
                  <div class="stat-row">
                    <span class="stat">{event.stat}</span>
                  </div>
                )}
                {event.links && event.links.length > 0 && (
                  <div class="links">
                    {event.links.map((link) => (
                      <a class="link" href={link.href}>
                        {link.label}
                        <ArrowRightIcon
                          width="1em"
                          height="1em"
                          aria-hidden="true"
                        />
                      </a>
                    ))}
                  </div>
                )}
              </article>
              {event.note && <p class="note">{event.note}</p>}
            </div>
          </li>
        );
      })
    }
  </ol>
</div>

<style>
  .timeline {
    position: relative;
  }

  .events {
    list-style: none;
    margin: 0;
    padding: 0;
  }

  /* The vertical rule the nodes sit on. Fades at both ends so it reads as a
     continuing thread rather than a bar with hard stops. */
  .spine {
    position: absolute;
    top: 0;
    bottom: 0;
    left: 11px;
    width: 2px;
    background: linear-gradient(
      180deg,
      var(--accent-overlay),
      var(--accent-regular),
      var(--accent-overlay)
    );
    transform: scaleY(0);
    transform-origin: top;
    transition: transform 1.1s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .spine.in {
    transform: scaleY(1);
  }

  .event {
    display: grid;
    /* Mobile: a narrow rail for the node, everything else in one column. */
    grid-template-columns: 24px 1fr;
    column-gap: 16px;
    align-items: start;
    margin-bottom: 40px;
  }

  .event:last-child {
    margin-bottom: 0;
  }

  .node-col {
    grid-row: 1;
    grid-column: 1;
    display: flex;
    justify-content: center;
    /* Line the dot up with the card's first line of text. */
    padding-top: 22px;
  }

  .node {
    width: 16px;
    height: 16px;
    border-radius: var(--border-radius-full);
    background: var(--accent-regular);
    /* The page background ring punches the node out of the spine, and the
       outer ring gives it a halo without adding a wrapper element. */
    border: 3px solid var(--gray-999);
    box-shadow: 0 0 0 3px var(--accent-overlay);
    transform: scale(0.2);
    opacity: 0;
    transition:
      transform 0.5s cubic-bezier(0.34, 1.56, 0.64, 1) 0.05s,
      opacity 0.4s ease 0.05s;
  }

  .reveal.in .node {
    transform: scale(1);
    opacity: 1;
  }

  .card-col {
    grid-row: 1;
    grid-column: 2;
    text-align: left;
  }

  /* inline-block so the card hugs whichever edge `.card-col` aligns it to
     once the layout alternates. */
  .card {
    display: inline-block;
    text-align: left;
    max-width: 400px;
    padding: 20px 22px;
    background: var(--gray-999);
    border: 1px solid var(--gray-800);
    border-radius: 14px;
    box-shadow: var(--shadow-md);
  }

  .card-meta {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-bottom: 8px;
  }

  /* Employer marks read as provenance, so they're held a step back from the
     meta text rather than fighting it for attention. Sized per mark and left
     to take whatever width that implies: a single box would either shrink the
     wide wordmark to nothing or blow the stacked one up. */
  .logo {
    display: flex;
    flex: 0 0 auto;
    color: var(--gray-300);
  }

  .logo :global(svg) {
    display: block;
    width: auto;
  }

  /* All-caps wordmark — its ink height is its cap height, so it matches the
     year's caps directly. */
  .logo-visa :global(svg) {
    height: 10px;
  }

  /* Two stacked lines plus the tag, so the mark needs roughly double the
     height to land at the same letter size. */
  .logo-best-buy :global(svg) {
    height: 18px;
  }

  .year {
    font-family: var(--font-brand);
    font-size: 13px;
    font-weight: 600;
    letter-spacing: 0.02em;
    color: var(--accent-dark);
  }

  .place {
    font-size: 12px;
    color: var(--gray-400);
  }

  .card-title {
    font-size: var(--text-md);
    letter-spacing: -0.01em;
    color: var(--gray-0);
  }

  .card-body,
  .card-more {
    margin-top: 7px;
    font-size: var(--text-sm);
    line-height: 1.55;
    text-wrap: pretty;
  }

  .card-body {
    color: var(--gray-200);
  }

  .card-more {
    margin-top: 9px;
    line-height: 1.6;
    color: var(--gray-300);
  }

  .stat-row {
    margin-top: 12px;
  }

  .stat {
    display: inline-block;
    padding: 4px 10px;
    font-family: var(--font-brand);
    font-size: 12px;
    font-weight: 600;
    color: var(--accent-dark);
    background: var(--accent-subtle-overlay);
    border: 1px solid var(--accent-overlay);
    border-radius: var(--border-radius-full);
  }

  .links {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-top: 14px;
  }

  .link {
    display: inline-flex;
    align-items: center;
    gap: 5px;
    padding: 5px 11px;
    font-family: var(--font-brand);
    font-size: 12.5px;
    font-weight: 600;
    color: var(--accent-dark);
    text-decoration: none;
    background: var(--gray-999);
    border: 1px solid var(--accent-overlay);
    border-radius: var(--border-radius-full);
    transition:
      background-color var(--theme-transition),
      color var(--theme-transition),
      border-color var(--theme-transition);
  }

  @media (hover: hover) {
    .link:hover {
      color: var(--accent-text-over);
      background: var(--accent-regular);
      border-color: var(--accent-regular);
    }
  }

  .note {
    max-width: 360px;
    margin-top: 10px;
    font-size: 13px;
    font-style: italic;
    color: var(--gray-400);
    text-wrap: pretty;
  }

  .reveal {
    opacity: 0;
    transform: translateY(18px);
    transition:
      opacity 0.7s cubic-bezier(0.16, 1, 0.3, 1),
      transform 0.7s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .reveal.in {
    opacity: 1;
    transform: none;
  }

  /* Alternating layout — the spine moves to the middle and cards take the
     column on either side of it. Held until there's room for two 400px cards
     plus the node rail. */
  @media (min-width: 900px) {
    .spine {
      left: 50%;
      transform: translateX(-50%) scaleY(0);
    }

    .spine.in {
      transform: translateX(-50%) scaleY(1);
    }

    .event {
      grid-template-columns: 1fr 64px 1fr;
      column-gap: 0;
      align-items: center;
      margin-bottom: 46px;
    }

    .node-col {
      grid-column: 2;
      padding-top: 0;
    }

    .event:nth-child(odd) .card-col {
      grid-column: 1;
      text-align: right;
    }

    .event:nth-child(even) .card-col {
      grid-column: 3;
      text-align: left;
    }

    /* Cards on the left get their trailing content pushed to the spine, so
       both sides stay anchored on the timeline rather than the outer margin. */
    .event:nth-child(odd) .links {
      justify-content: flex-end;
    }

    .event:nth-child(odd) .note {
      margin-left: auto;
      text-align: right;
    }

    .card-title {
      font-size: var(--text-lg);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .reveal,
    .spine,
    .node {
      opacity: 1;
      transform: none;
      transition: none;
    }

    .spine {
      transform: scaleY(1);
    }

    .link {
      transition: none;
    }
  }

  @media (prefers-reduced-motion: reduce) and (min-width: 900px) {
    .spine {
      transform: translateX(-50%) scaleY(1);
    }
  }
</style>

<script>
  function initTimeline() {
    const timeline = document.querySelector<HTMLElement>('[data-timeline]');
    if (!timeline) return;

    // Both DOMContentLoaded and astro:page-load can fire for one page.
    if (timeline.dataset.timelineReady) return;
    timeline.dataset.timelineReady = '1';

    let pending = [
      ...timeline.querySelectorAll<HTMLElement>('.reveal, [data-spine]'),
    ];

    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
      pending.forEach((el) => el.classList.add('in'));
      return;
    }

    let queued = false;
    const update = () => {
      queued = false;

      // Held back from the bottom edge so an entry animates once it has
      // properly cleared the fold rather than the instant it touches it.
      // Anything already scrolled above the fold has a negative top and so
      // reveals too — that's what keeps entries from being stranded when the
      // page jumps (a restored scroll position, or a flick past a card)
      // instead of scrolling through them.
      const threshold = window.innerHeight * 0.92;
      pending = pending.filter((el) => {
        if (el.getBoundingClientRect().top > threshold) return true;
        el.classList.add('in');
        return false;
      });

      if (pending.length === 0) {
        window.removeEventListener('scroll', onScroll);
        window.removeEventListener('resize', onScroll);
      }
    };

    // Scroll fires far more often than we can paint, so coalesce to one
    // measurement per frame — getBoundingClientRect forces layout.
    const onScroll = () => {
      if (queued) return;
      queued = true;
      requestAnimationFrame(update);
    };

    window.addEventListener('scroll', onScroll, { passive: true });
    window.addEventListener('resize', onScroll, { passive: true });

    update();
  }

  initTimeline();
  document.addEventListener('astro:page-load', initTimeline);
</script>
