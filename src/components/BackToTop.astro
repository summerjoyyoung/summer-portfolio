---
import { ArrowRightIcon } from '@radix-ui/react-icons';
---

<button class="back-to-top" aria-label="Back to top">
  Back to top
  <ArrowRightIcon width="1em" height="1em" aria-hidden="true" />
</button>

<style>
  .back-to-top {
    /* Position */
    position: fixed;
    bottom: 7rem;
    right: 2rem;
    z-index: 50;

    /* Layout */
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);

    /* Sizing — mirrors Radix rt-r-size-2 */
    height: var(--space-6);
    padding-inline: var(--space-3);
    border-radius: max(var(--radius-2), var(--radius-full));

    /* Appearance — exact tokens Radix outline variant uses */
    background-color: white;
    box-shadow: inset 0 0 0 1px var(--accent-a8);
    color: var(--accent-a11);
    font-family: var(--default-font-family);
    font-size: var(--font-size-2);
    line-height: var(--line-height-2);
    letter-spacing: var(--letter-spacing-2);
    font-weight: 500;
    cursor: pointer;
    border: none;

    /* Visibility */
    opacity: 0;
    pointer-events: none;
    transform: translateY(0.5rem);
    transition:
      opacity var(--theme-transition),
      transform var(--theme-transition),
      background-color var(--theme-transition);
  }

  @media (hover: hover) {
    .back-to-top:hover {
      background-color: var(--accent-9);
      color: var(--accent-contrast);
      box-shadow: inset 0 0 0 1px var(--accent-9);
    }
  }

  .back-to-top:active {
    background-color: var(--accent-10);
    color: var(--accent-contrast);
    box-shadow: inset 0 0 0 1px var(--accent-10);
  }

  .back-to-top.visible {
    opacity: 1;
    pointer-events: auto;
    transform: translateY(0);
  }

  .back-to-top :global(svg) {
    transform: rotate(-90deg);
  }
</style>

<script>
  function initBackToTop() {
    const btn = document.querySelector('.back-to-top');
    if (!btn) return;

    window.addEventListener(
      'scroll',
      () => {
        btn.classList.toggle('visible', window.scrollY > 200);
      },
      { passive: true }
    );

    btn.addEventListener('click', () => {
      window.scrollTo({ top: 0, behavior: 'smooth' });
    });
  }

  document.addEventListener('DOMContentLoaded', initBackToTop);
  document.addEventListener('astro:page-load', initBackToTop);
</script>
