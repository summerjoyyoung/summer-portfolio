---
// @ts-ignore — Node crypto is available in Astro frontmatter at build time
import { createHash } from 'node:crypto';

const password = import.meta.env.PUBLIC_SITE_PASSWORD || '';
const passwordHash = password
  ? createHash('sha256').update(password).digest('hex')
  : '';
---

<div class="password-gate" role="dialog" aria-modal="true" aria-label="Password required">
  <div
    class="radix-themes"
    data-accent-color="purple"
    data-gray-color="slate"
    data-has-background="false"
    data-panel-background="translucent"
    data-radius="medium"
    data-scaling="100%"
  >
    <div class="gate-card">
      <svg class="gate-icon" width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <rect x="3" y="11" width="18" height="11" rx="2" ry="2" />
        <path d="M7 11V7a5 5 0 0 1 10 0v4" />
        <circle cx="12" cy="16.5" r="1.5" />
      </svg>

      <h1 class="gate-title">This page is password-protected</h1>
      <p class="gate-subtitle">Enter the password to continue</p>

      <form class="gate-form" autocomplete="off">
        <div class="gate-input-group">
          <label for="gate-password" class="sr-only">Password</label>
          <div class="rt-TextFieldRoot rt-r-size-2 rt-variant-surface">
            <input
              id="gate-password"
              type="password"
              class="rt-reset rt-TextFieldInput"
              placeholder="Enter password"
              autocomplete="current-password"
              required
            />
          </div>
        </div>
        <button
          type="submit"
          class="rt-reset rt-BaseButton rt-Button rt-r-size-3 rt-variant-solid"
          data-accent-color="purple"
        >
          Continue
        </button>
        <p class="gate-error" role="alert" aria-live="polite" hidden>
          Incorrect password. Please try again.
        </p>
      </form>

      <noscript>
        <p class="gate-noscript">JavaScript is required to view this page.</p>
      </noscript>
    </div>
  </div>
</div>

<script is:inline define:vars={{ passwordHash }}>
  (function () {
    var gate = document.querySelector('.password-gate');
    if (!gate) return;

    // Already authenticated — remove gate
    if (!document.documentElement.hasAttribute('data-protected')) {
      gate.remove();
      return;
    }

    // No password configured — auto-unlock
    if (!passwordHash) {
      document.documentElement.removeAttribute('data-protected');
      gate.remove();
      return;
    }

    var form = gate.querySelector('.gate-form');
    var input = document.getElementById('gate-password');
    var error = gate.querySelector('.gate-error');
    var card = gate.querySelector('.gate-card');

    // Focus the password input
    if (input) input.focus();

    form.addEventListener('submit', function (e) {
      e.preventDefault();
      var value = input.value;

      // Hash input with SubtleCrypto
      var encoder = new TextEncoder();
      var data = encoder.encode(value);
      crypto.subtle.digest('SHA-256', data).then(function (hashBuffer) {
        var hashArray = Array.from(new Uint8Array(hashBuffer));
        var hashHex = hashArray
          .map(function (b) {
            return b.toString(16).padStart(2, '0');
          })
          .join('');

        if (hashHex === passwordHash) {
          // Store auth in sessionStorage
          sessionStorage.setItem('portfolio-auth', 'authenticated');
          // Unlock page
          document.documentElement.removeAttribute('data-protected');
          // Animate gate out
          gate.classList.add('gate-exit');
          gate.addEventListener(
            'transitionend',
            function () {
              gate.remove();
            },
            { once: true }
          );
        } else {
          // Show error
          error.hidden = false;
          input.value = '';
          input.focus();
          // Shake animation
          card.classList.add('shake');
          setTimeout(function () {
            card.classList.remove('shake');
          }, 400);
        }
      });
    });
  })();
</script>

<style is:global>
  .password-gate {
    position: fixed;
    inset: 0;
    z-index: 10000;
    display: flex;
    align-items: center;
    justify-content: center;
    background-color: var(--gray-999);
    transition: opacity 0.3s ease-out;
  }

  .password-gate.gate-exit {
    opacity: 0;
  }

  .gate-card {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 16px;
    padding: 48px 32px;
    max-width: 400px;
    width: 100%;
    text-align: center;
  }

  .gate-icon {
    color: var(--accent-regular);
    margin-bottom: 8px;
  }

  .gate-title {
    font-family: var(--font-brand);
    font-size: var(--text-xl);
    color: var(--gray-0);
    font-weight: 600;
    line-height: 1.25;
    margin: 0;
  }

  .gate-subtitle {
    font-family: var(--font-body);
    font-size: var(--text-md);
    color: var(--gray-400);
    margin: 0;
  }

  .gate-form {
    display: flex;
    flex-direction: column;
    gap: 12px;
    width: 100%;
    margin-top: 8px;
  }

  .gate-input-group {
    width: 100%;
  }

  .gate-error {
    font-family: var(--font-body);
    font-size: var(--text-sm);
    color: var(--red-9, #e5484d);
    margin: 0;
  }

  .gate-noscript {
    font-family: var(--font-body);
    font-size: var(--text-sm);
    color: var(--gray-400);
    margin: 0;
  }

  @keyframes shake {
    0%,
    100% {
      transform: translateX(0);
    }
    20%,
    60% {
      transform: translateX(-8px);
    }
    40%,
    80% {
      transform: translateX(8px);
    }
  }

  .shake {
    animation: shake 0.4s ease-in-out;
  }

  @media (prefers-reduced-motion: reduce) {
    .shake {
      animation: none;
    }

    .password-gate {
      transition: none;
    }

    .password-gate.gate-exit {
      display: none;
    }
  }
</style>
