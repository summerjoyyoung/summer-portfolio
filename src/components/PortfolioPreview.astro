---
import type { CollectionEntry } from 'astro:content';

interface Props {
  project: CollectionEntry<'work'>;
}

const { data, id } = Astro.props.project;

const year = data.year ?? String(data.publishDate.getFullYear());
// The most specific tag reads as the project's discipline ("Design Systems",
// "Case Study") — the broader ones ("Design", "Engineering") come first.
const discipline = data.tags.at(-1);
---

<a class="card" href={`/work/${id}`}>
  <div class="cover">
    <img
      src={data.img}
      alt={data.img_alt || ''}
      loading="lazy"
      decoding="async"
    />
  </div>
  <div class="content">
    <div class="heading">
      <span class="title">{data.title}</span>
      <span class="year">{year}</span>
    </div>
    <p class="description">{data.description}</p>
    {discipline && <div class="discipline">{discipline}</div>}
  </div>
</a>

<style>
  .card {
    display: flex;
    flex-direction: row;
    align-items: center;
    gap: 20px;
    width: 100%;
    padding: 16px;
    background: var(--gray-999);
    border: 1px solid var(--gray-800);
    border-radius: 14px;
    text-decoration: none;
    transition:
      transform var(--theme-transition),
      box-shadow var(--theme-transition),
      border-color var(--theme-transition);
  }

  .card:hover {
    transform: translateY(-4px);
    box-shadow: var(--shadow-lg);
    border-color: var(--accent-overlay);
  }

  .cover {
    flex: 0 0 88px;
    width: 88px;
    height: 88px;
    overflow: hidden;
    background: var(--gray-900);
    border: 1px solid var(--gray-800);
    border-radius: 10px;
  }

  img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.5s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .card:hover img {
    transform: scale(1.04);
  }

  .content {
    flex: 1;
    min-width: 0;
  }

  .heading {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 12px;
  }

  .title {
    font-family: var(--font-brand);
    font-size: var(--text-md);
    font-weight: 600;
    letter-spacing: -0.01em;
    color: var(--gray-0);
    transition: color var(--theme-transition);
  }

  .card:hover .title {
    color: var(--accent-dark);
  }

  .year {
    font-size: 13px;
    color: var(--gray-400);
    white-space: nowrap;
  }

  .description {
    margin: 6px 0 0;
    font-size: var(--text-sm);
    color: var(--gray-200);
    text-wrap: pretty;
    /* Clamped so cards keep an even rhythm across the grid — the source
       descriptions run much longer than the blurbs in the design. */
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .discipline {
    margin-top: 10px;
    font-family: var(--font-brand);
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--accent-dark);
  }

  @media (min-width: 800px) {
    .cover {
      flex-basis: 108px;
      width: 108px;
      height: 108px;
    }

    .title {
      font-size: var(--text-lg);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .card,
    img {
      transition: none;
    }

    .card:hover {
      transform: none;
    }

    .card:hover img {
      transform: none;
    }
  }
</style>
