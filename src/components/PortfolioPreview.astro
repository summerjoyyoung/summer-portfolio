---
import type { CollectionEntry } from 'astro:content';

interface Props {
  project: CollectionEntry<'work'>;
}

const { data, slug } = Astro.props.project;
---

<a
  class="card rt-BaseCard rt-Card rt-r-size-2 rt-variant-surface"
  href={`/work/${slug}`}
>
  <div class="img-wrapper">
    <img
      src={data.img}
      alt={data.img_alt || ''}
      loading="lazy"
      decoding="async"
    />
  </div>
  <div class="content">
    <span class="title">{data.title}</span>
    <p class="description">{data.description}</p>
  </div>
</a>

<style>
  .card {
    display: flex;
    flex-direction: row;
    align-items: center;
    gap: 20px;
    padding: 16px 20px;
    text-decoration: none;
    transition:
      box-shadow var(--theme-transition),
      transform var(--theme-transition);
  }

  .card:hover {
    transform: translateY(-2px);
  }

  .img-wrapper {
    width: 112px;
    height: 80px;
    flex-shrink: 0;
    overflow: hidden;
    border-radius: var(--border-radius);
  }

  img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .content {
    display: flex;
    flex-direction: column;
    gap: 6px;
    min-width: 0;
  }

  .title {
    font-family: var(--font-brand);
    font-size: var(--text-lg);
    font-weight: 500;
    color: var(--gray-0);
  }

  .description {
    font-size: var(--text-sm);
    color: var(--gray-400);
    margin: 0;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  @media (min-width: 800px) {
    .card {
      gap: 28px;
      padding: 20px 24px;
    }

    .img-wrapper {
      width: 160px;
      height: 112px;
      border-radius: var(--border-radius);
    }

    .title {
      font-size: var(--text-xl);
    }

    .description {
      font-size: var(--text-base);
      -webkit-line-clamp: 3;
    }
  }
</style>
