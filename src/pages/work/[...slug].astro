---
import { type CollectionEntry, getCollection, render } from 'astro:content';

import BaseLayout from '../../layouts/BaseLayout.astro';

import ContactCTA from '../../components/ContactCTA.astro';
import { ArrowLeftIcon } from '@radix-ui/react-icons';
import Pill from '../../components/Pill.astro';
import InfoCard from '../../components/InfoCard.astro';
import ChapterNav, { type Chapter } from '../../components/ChapterNav.astro';

interface Props {
  entry: CollectionEntry<'work'>;
}

// This is a dynamic route that generates a page for every Markdown file in src/content/
// Read more about dynamic routes and this `getStaticPaths` function in the Astro docs:
// https://docs.astro.build/en/core-concepts/routing/#dynamic-routes
export async function getStaticPaths() {
  const work = await getCollection('work');
  return work.map((entry) => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content, headings } = await render(entry);

// Only H2s become chapters — the numbering here has to line up with the
// counter on the headings themselves, which also only counts H2s.
const chapters: Chapter[] = headings
  .filter((heading) => heading.depth === 2)
  .map((heading) => ({ id: heading.slug, text: heading.text }));

const year = entry.data.year ?? String(entry.data.publishDate.getFullYear());
---

<BaseLayout title={entry.data.title} description={entry.data.description}>
  <main class="page-layout">
    <a class="back-link link-underline" href="/work/"
      ><ArrowLeftIcon
        width="1em"
        height="1em"
        aria-hidden="true"
        style={{ verticalAlign: 'middle' }}
      /> Work</a
    >

    <div class="case-hero">
      <div class="case-hero-text">
        <div class="tags">
          {
            entry.data.tags.map((tag, i) => (
              <Pill variant={i === 0 ? 'accent' : 'neutral'}>{tag}</Pill>
            ))
          }
        </div>
        <h1>{entry.data.title}</h1>
        <p class="description">{entry.data.description}</p>
      </div>
      <figure class="case-hero-media">
        <img src={entry.data.img} alt={entry.data.img_alt || ''} />
      </figure>
    </div>

    <div class="page-content">
      <aside class="sidebar">
        <InfoCard
          role={entry.data.role}
          tools={entry.data.tools}
          scope={entry.data.scope}
          timeline={entry.data.timeline}
          year={year}
        />
        {chapters.length > 0 && <ChapterNav chapters={chapters} />}
      </aside>
      <article class="main-content">
        <Content />
      </article>
    </div>
  </main>
  <ContactCTA />
</BaseLayout>

<script>
  import Gifa11y from 'gifa11y';

  // Wrap each GIF so the absolute-positioned pause button anchors to the
  // image, not the viewport. Move the image's vertical margins onto the
  // wrapper so the button doesn't float in the margin space above the GIF.
  document.querySelectorAll('.main-content img[src$=".gif"]').forEach((el) => {
    const img = el as HTMLElement;
    const wrap = document.createElement('div');
    wrap.className = 'gifa11y-wrap';
    wrap.style.marginTop = img.style.marginTop;
    wrap.style.marginBottom = img.style.marginBottom;
    img.style.marginTop = '';
    img.style.marginBottom = '';
    img.replaceWith(wrap);
    wrap.appendChild(img as Node);
  });

  const instance = new Gifa11y({
    container: '.main-content',
    buttonBackground: 'var(--accent-regular)',
    buttonBackgroundHover: 'var(--accent-dark)',
    buttonBorder: '1px solid var(--gray-800)',
    buttonBorderRadius: 'var(--border-radius-full)',
    buttonIconColor: 'var(--accent-text-over)',
    buttonFocusColor: 'var(--accent-overlay)',
    buttonIconSize: '1rem',
  });

  // Astro module scripts run after DOMContentLoaded, so gifa11y's
  // internal listener never fires. Trigger findNew() manually if the
  // DOM is already ready.
  if (document.readyState !== 'loading') {
    instance.findNew();
  }

  // box-shadow and position are hardcoded inside gifa11y's shadow DOM.
  // Inject overrides: remove the drop shadow and anchor the button to top-right.
  document.querySelectorAll('.main-content gifa11y-button').forEach((host) => {
    const s = document.createElement('style');
    s.textContent = 'button { box-shadow: none; inset: 0 0 auto auto; }';
    host.shadowRoot?.appendChild(s);
  });
</script>

<style>
  /* Sized so the rail + gap + the article's 760px cap fill the content box
     exactly, leaving no dead space to the right of the article. */
  .page-layout {
    --rail-width: 250px;
    --rail-gap: 64px;
    --article-width: 760px;

    display: flex;
    flex-direction: column;
    width: 100%;
    max-width: calc(
      var(--rail-width) + var(--rail-gap) + var(--article-width) + 48px * 2
    );
    margin-inline: auto;
    padding-inline: 24px;
    margin-bottom: 80px;
    min-height: calc(100vh - 101px);
  }

  .back-link {
    display: none;
    margin-bottom: 8px;
  }

  .case-hero {
    display: flex;
    flex-direction: column;
    gap: 32px;
    padding-bottom: 40px;
    border-bottom: 1px solid var(--gray-800);
    margin-bottom: 40px;
  }

  .case-hero-text h1 {
    font-size: var(--text-3xl);
    line-height: 1.03;
    letter-spacing: -0.015em;
    color: var(--gray-0);
  }

  .tags {
    display: flex;
    gap: 8px;
    margin-bottom: 20px;
  }

  .tags :global(.rt-Badge) {
    font-family: var(--font-brand);
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .description {
    font-size: var(--text-md);
    line-height: 1.55;
    margin-top: 18px;
    text-wrap: pretty;
  }

  .case-hero-media img {
    width: 100%;
    border-radius: 16px;
    border: 1px solid var(--gray-800);
  }

  .page-content {
    display: flex;
    flex-direction: column;
    gap: 32px;
  }

  /* The info card carries role/tools, so it stays visible on narrow screens
     stacked above the article. The chapter rail stays desktop-only. */
  .sidebar {
    display: flex;
    flex-direction: column;
    gap: 24px;
  }

  .sidebar :global(.chapter-nav) {
    display: none;
  }

  /* Two-column article: prose and figures in column 1, margin notes parked in
     the gutter. Grid auto-placement lands a `.gutter-note` on the same row as
     the block it follows, so notes sit beside their figure rather than below. */
  .main-content {
    --note-width: 190px;
    --note-gap: 40px;

    display: grid;
    grid-template-columns: minmax(0, 1fr);
    counter-reset: chapter;
  }

  .main-content > :global(*) {
    grid-column: 1;
  }

  /* Astro gives hydrated islands `display: contents`, which would hand grid
     item status to the component's own root and let it auto-place into the
     note gutter. Give the island a box so it stays in the content column. */
  .main-content > :global(astro-island) {
    display: block;
  }

  .main-content > :global(* + *) {
    margin-top: 16px;
  }

  /* Direct children only: the counter has to stay in step with ChapterNav,
     which numbers the top-level H2s the article was rendered with. */
  .main-content > :global(h2) {
    counter-increment: chapter;
    display: flex;
    align-items: center;
    gap: 18px;
    border-top: 1px solid var(--gray-800);
    padding-top: 34px;
    margin-top: 56px;
    margin-bottom: 22px;
    color: var(--gray-0);
    scroll-margin-top: 24px;
  }

  .main-content > :global(h2)::before {
    content: counter(chapter, decimal-leading-zero);
    font-family: var(--font-brand);
    font-size: 44px;
    font-weight: 600;
    line-height: 1;
    letter-spacing: -0.02em;
    color: var(--accent-regular);
  }

  .main-content :global(h3),
  .main-content :global(h4),
  .main-content :global(h5) {
    margin-top: var(--space-6);
    margin-bottom: var(--space-3);
    scroll-margin-top: 24px;
  }

  /* Direct children only: Callout, Note and PullQuote set their own measure,
     and a descendant selector here would override it. */
  .main-content > :global(p) {
    line-height: 1.78;
    text-wrap: pretty;
  }

  .main-content :global(img) {
    border-radius: var(--border-radius);
    box-shadow: var(--shadow-sm);
    border: 1px solid var(--gray-800);
  }

  .main-content :global(figcaption) {
    font-size: 13px;
    color: var(--gray-400);
    margin-top: 12px;
  }

  .main-content :global(.gifa11y-wrap) {
    position: relative;
  }

  /* Plain markdown quotes only — PullQuote carries its own accent rule, and a
     descendant selector would draw a second one inside it. */
  .main-content > :global(blockquote) {
    font-size: var(--text-lg);
    font-family: var(--font-brand);
    font-weight: 600;
    line-height: 1.1;
    padding-inline-start: 24px;
    border-inline-start: 4px solid var(--accent-dark);
    color: var(--gray-0);
  }

  .main-content :global(a) {
    text-decoration: 1px solid underline transparent;
    text-underline-offset: 0.25em;
    transition: text-decoration-color var(--theme-transition);
  }

  .main-content :global(a:hover),
  .main-content :global(a:focus) {
    text-decoration-color: currentColor;
  }

  @media (min-width: 800px) {
    .page-layout {
      padding-inline: 48px;
    }

    .back-link {
      display: block;
    }

    .case-hero {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 48px;
      align-items: center;
      padding-bottom: 60px;
      margin-bottom: 56px;
    }

    .case-hero-text h1 {
      font-size: var(--text-4xl);
    }

    .description {
      font-size: 19px;
    }

    .page-content {
      display: grid;
      grid-template-columns: var(--rail-width) minmax(0, var(--article-width));
      gap: var(--rail-gap);
      align-items: start;
    }

    .sidebar {
      position: sticky;
      top: 28px;
      max-height: calc(100vh - 56px);
      overflow-y: auto;
    }

    .sidebar :global(.chapter-nav) {
      display: block;
    }

    .main-content {
      grid-template-columns: minmax(0, 1fr) var(--note-width);
      column-gap: var(--note-gap);
    }

    .main-content > :global(.gutter-note) {
      grid-column: 2;
    }

    .main-content > :global(blockquote) {
      font-size: var(--text-2xl);
    }
  }
</style>
