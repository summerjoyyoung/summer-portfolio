  "devDependencies": {
    "@typescript-eslint/parser": "^8.51.0",
    "cspell": "^9.4.0",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-astro": "^1.2.0",
    "prettier": "^3.3.0",
